<%- include('../partials/_navbar.ejs', {title: 'Add New Movie' }) %>

  <body>
    <div class="form-container">
      <h1>Add a New Movie</h1>
      <form action="/movies" method="POST">
        <div class="form-group">
          <label for="title">Title:</label>
          <input type="text" id="title" name="title" required>
        </div>
        <div class="form-group">
          <label for="year">Release Year:</label>
          <input type="number" id="year" name="year" required>
        </div>
        <div class="form-group">
          <label for="genre">Genre:</label>
          <select id="genre" name="genre" required>
            <% ['Action', 'Comedy' , 'Drama' , 'Horror' , 'Sci-Fi' , 'Romance' , 'Thriller' , 'Other' ].forEach(genre=>{%>
              <option value="<%= genre %>">
                <%= genre.charAt(0).toUpperCase() + genre.split('').slice(1).join('') %>
              </option>
              <% }) %>
          </select>
        </div>
        <div id="actors-container" class="form-group">
          <label for="cast">Cast:</label>
          <select id="cast" name="cast" multiple>
            <% actors.forEach(actor=> { %>
              <option value="<%= actor._id %>">
                <%= actor.name.charAt(0).toUpperCase() + actor.name.split('').slice(1).join('') %>
              </option>
              <% }); %>
          </select>
        </div>
        <div class="form-group">
          <label for="posterUrl">Poster URL:</label>
          <input type="url" id="posterUrl" name="posterUrl">
        </div>
        <input type="submit" value="Add Movie" class="btn-submit">
      </form>
    </div>
  </body>

  </html>