<%- include('../partials/_navbar.ejs', {title: 'Edit Movie' }) %>

  <body>
    <h1>Edit Movie</h1>
    <form action="/movies/<%= movie._id %>?_method=PUT" method="POST">
      <div>
        <label for="title">Title:</label>
        <input type="text" id="title" name="title" required value="<%= movie.title %>">
      </div>
      <div>
        <label for="year">Release Year:</label>
        <input type="number" id="year" name="year" required value="<%= movie.year %>">
      </div>
      <div>
        <label for="genre">Genre:</label>
        <select id="genre" name="genre" required value="<%= movie.genre %>">
          <% ['Action', 'Comedy' , 'Drama' , 'Horror' , 'Sci-Fi' , 'Romance' , 'Thriller' , 'Other' ].forEach(genre=> {%>
            <option value="<%= genre %>">
              <%= genre.charAt(0).toUpperCase() + genre.split('').slice(1).join('') %>
            </option>
            <% }) %>
        </select>
      </div>
      <div id="actors-container">
        <label for="cast">Cast:</label>
        <select id="cast" name="cast" multiple>
          <% actors.forEach(actor => { %>
            <option value="<%= actor._id %>" <%= movie.cast.includes(actor._id) ? 'selected' : '' %>>
              <%= actor.name.charAt(0).toUpperCase() + actor.name.split('').slice(1).join('') %>
            </option>
          <% }); %>
        </select>
      </div>
      <div>
        <label for="posterUrl">Poster URL:</label>
        <input type="url" id="posterUrl" name="posterUrl" value="<%= movie?.posterUrl %>">
      </div>
      <input type="submit" value="Update Movie">
    </form>
  </body>

  </html>