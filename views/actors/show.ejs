<%- include('../partials/_navbar.ejs', {title: actor.name }) %>

<body>
  <div class="actor-show-container">
    <img src="<%= actor.photoUrl %>" class="actor-photo" alt="<%= actor.name %>">

    <div class="actor-details">
      <h1>
        <%= actor.name %>
      </h1>
      <p><strong>Birth Year:</strong>
        <%= actor.birthYear %>
      </p>
      <p><strong>Added By:</strong>
        <%= actor.addedBy.username %>
      </p>

      <% if (user && user._id.toString()===actor.addedBy._id.toString()) { %>
        <div class="actor-actions">
          <form action="/actors/<%= actor._id %>?_method=DELETE" method="POST">
            <button type="submit" class="btn-delete">Delete Actor</button>
          </form>
          <a href="/actors/<%= actor._id %>/edit" class="btn-edit">Edit Actor</a>
        </div>
        <% } %>
    </div>
  </div>

  <div class="actor-movies">
    <h2>Movies:</h2>
    <% if (movies.length> 0) { %>
      <ul>
        <% movies.forEach(movie=> { %>
          <li>
            <a href="/movies/<%= movie._id %>">
              <img src="<%= movie.posterUrl || '/images/placeholder.jpg' %>" alt="<%= movie.title %>">
              <p>
                <%= movie.title %>
              </p>
            </a>
          </li>
          <% }); %>
      </ul>
      <% } else { %>
        <p>No movies information available.</p>
        <% } %>
  </div>
</body>
  </html>